# apps/backend environment.
#
# Copy to .env and fill in. In production this file is supplied to the container
# at runtime via `env_file` in compose.prod.yml — it is NOT baked into the image
# (root .dockerignore excludes .env and .env.*).
#
# Vars are grouped by whether the process survives without them. Read the
# "REQUIRED" block as: missing any of these and the backend is broken, in some
# cases without an obvious error.

# ---------------------------------------------------------------------------
# REQUIRED — server
# ---------------------------------------------------------------------------
# The Dockerfile pins PORT=8000 and nginx.prod.conf proxies to backend:8000.
# Only override if you change both.
PORT=8000

# Comma-separated list of allowed browser origins, no trailing slash.
# Auth cookies are set with `secure: true, sameSite: 'none'` (auth.controller.ts,
# identity.middleware.ts), so this must match the frontend origin exactly or the
# browser silently drops the session cookie and users appear logged out.
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# REQUIRED — datastores
# ---------------------------------------------------------------------------
# Postgres (Neon in production). Prisma reads this via prisma.config.ts.
DATABASE_URL=postgresql://user:password@host:5432/quickhire?sslmode=require

# Redis (Redis Cloud in production). Backs all nine in-process BullMQ workers.
# NOTE: the worker imports in src/index.ts are wrapped in try/catch, so a bad
# URL here does NOT crash the server — the API stays healthy while every
# background job (resume analysis, jobs ingest, interview feedback) silently
# never runs. Check the boot logs, not just /health.
REDIS_URL=redis://default:password@host:6379

# ---------------------------------------------------------------------------
# REQUIRED — auth
# ---------------------------------------------------------------------------
JWT_SECRET=

# Shared secret for the agent -> backend internal API (transcript persistence
# and recording upload). Must be byte-identical to AGENT_INTERNAL_SECRET in
# apps/agent-worker-python/.env.local, or those calls 401.
AGENT_INTERNAL_SECRET=

# ---------------------------------------------------------------------------
# REQUIRED — Cloudflare R2 (resume/avatar/recording storage)
# ---------------------------------------------------------------------------
# src/utils/upload.ts throws at *import* time if any of these four is missing,
# which presents as the process dying on boot with no request ever served.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# REQUIRED — Azure OpenAI (interview feedback, resume ATS judge)
# ---------------------------------------------------------------------------
# Same credential the Python agent calls AZURE_OPENAI_API_KEY. Different name,
# same value.
AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com
AZURE_SECRET_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
OPENAI_TTT_MODEL=gpt-5-mini

# ---------------------------------------------------------------------------
# REQUIRED — LiveKit (real-time interview rooms)
# ---------------------------------------------------------------------------
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---------------------------------------------------------------------------
# REQUIRED — GitHub profile enrichment
# ---------------------------------------------------------------------------
GITHUB_PAT=

# ---------------------------------------------------------------------------
# OPTIONAL — Adzuna job source
# ---------------------------------------------------------------------------
# The adapter self-disables if the id/key are absent; Remotive and Arbeitnow
# need no credentials and keep working.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb
