// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}

enum Provider {
  GOOGLE
  LOCAL
}

enum InterviewStatus {
  SCHEDULED
  ONGOING
  COMPLETED
}

enum UploadStatus {
  UPLOADED_LOCAL
  PARSING
  PARSED
  UPLOADING
  COMPLETE
  FAILED
}

enum MessageRole {
  User
  Assistant
}

enum InterviewType {
  REAL
  PRACTICE
}

enum RecordingStatus {
  NONE
  PROCESSING
  READY
  FAILED
}

enum AnalysisStatus {
  UPLOADING
  PARSING
  PARSED
  ANALYZING
  COMPLETE
  FAILED
}

enum Experience {
  beginner
  junior
  mid
  senior
  staff
}

enum JobSource {
  REMOTIVE
  ARBEITNOW
  ADZUNA
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  OTHER
}

enum ResumeParseStatus {
  PARSING
  PARSED
  FAILED
}

model User {
  id        String          @id @default(uuid())
  username  String?         @unique
  displayName String?
  bio       String?
  avatarKey String?
  email     String          @unique
  provider  Provider        @default(LOCAL)
  password  String?
  resumeKey     String?
  resumeStatus  ResumeParseStatus?
  resumeError   String?
  summary       Json?
  interview Interview[]
  resumeAnalyses ResumeAnalysis[]
  savedJobs SavedJob[]
  refreshToken String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now())
}

model Interview {
  id        String          @id @default(uuid())
  jobRole   String
  resume    Resume?
  startAt   DateTime?
  endAt     DateTime?
  summary   String?
  status    InterviewStatus @default(SCHEDULED)
  type      InterviewType   @default(REAL)
  skill     String?
  experience  Experience    @default(beginner)
  resultId  String?          @unique
  result    Result?          @relation(fields: [resultId], references: [id])
  messages  Message[]
  recordingKey        String?
  recordingStatus     RecordingStatus @default(NONE)
  recordingDurationMs Int?
  isPublic  Boolean         @default(false)
  githubMetadata  Json?
  userId    String  
  user      User            @relation(fields: [userId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now())
}

model Resume {
  id          String          @id @default(uuid())
  name        String
  size        Float
  ext         String
  status      UploadStatus    @default(UPLOADED_LOCAL)
  parsed      Json?            
  error       String?
  url         String?
  interviewId String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now())
  interview   Interview       @relation(fields: [interviewId], references: [id])
}

model Message {
  id          Int             @id @default(autoincrement())
  content     String          
  role        MessageRole     @default(User) 
  interviewId String
  interview   Interview       @relation(fields: [interviewId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now())
}

model Result {
  id            String          @id @default(uuid())
  score         Float
  report        Json?
  schemaVersion Int             @default(2)
  analyzedAt    DateTime?
  interview     Interview?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now())
}

model ResumeAnalysis {
  id               String         @id @default(uuid())
  name             String
  size             Float
  ext              String
  status           AnalysisStatus @default(UPLOADING)
  url              String?
  parsed           Json?
  summary          Json?
  targetRole       String?
  targetExperience Experience?
  targetJobId      String?
  targetJob        Job?           @relation(fields: [targetJobId], references: [id])
  targetJdText     String?
  overallScore     Float?
  report           Json?
  error            String?
  userId           String?
  user             User?          @relation(fields: [userId], references: [id])
  guestId          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now())

  @@index([userId])
  @@index([guestId])
}

model Job {
  id             String    @id @default(uuid())
  source         JobSource
  externalId     String
  title          String
  company        String
  companyLogo    String?
  location       String?
  remote         Boolean   @default(false)
  jobType        JobType   @default(OTHER)
  category       String?
  description    String
  tags           String[]
  salaryMin      Float?
  salaryMax      Float?
  salaryCurrency String?
  url            String
  postedAt       DateTime?
  fetchedAt      DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  resumeAnalyses ResumeAnalysis[]
  savedBy        SavedJob[]

  @@unique([source, externalId])
  @@index([postedAt])
  @@index([remote])
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
}

